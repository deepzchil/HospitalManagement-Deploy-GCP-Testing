<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>MediCare HMS</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/site.css" />
<style>
body{
background:#f8f9fa;
font-family:Segoe UI;
}

.sidebar{
width:250px;
height:100vh;
position:fixed;
background:#0d6efd;
padding-top:20px;
color:white;
}

.sidebar a{
display:block;
color:white;
padding:15px;
text-decoration:none;
transition:0.3s;
}

.sidebar a:hover{
background:white;
color:#0d6efd;
padding-left:25px;
}

.content{
margin-left:260px;
padding:30px;
}

.card{
border:none;
border-radius:15px;
box-shadow:0 8px 20px rgba(0,0,0,.08);
transition:.3s;
}

.card:hover{
transform:translateY(-5px);
}

.btn{
border-radius:10px;
}
</style>
</head>

<body>

<div class="sidebar">
<h3 class="text-center">🏥 MediCare</h3>
<hr>

<a href="/">Dashboard</a>
<a href="/Doctors">Doctors</a>
<a href="/Patients">Patients</a>
<a href="/Appointments">Appointments</a>
<a href="/Billing">Billing</a>
<a href="/Reports">Reports</a>
<a href="/Prescription">Prescription</a>
<a href="/Identity/Account/Login">Login</a>

</div>

<div class="content">
@RenderBody()
</div>

</body>
</html>